LOG_LEVEL=INFO
LOG_SENSITIVE=false
PLUMID_API_KEY=change_me_internal_token
AUTH_SECRET=change_this_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:19006
DATABASE_URL=sqlite:///./app.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@plumid.local
FRONTEND_BASE_URL=http://localhost:3000
RL_DEFAULT_PER_MIN=60
RL_BURST=120
RL_LOGIN_PER_MIN=10
RL_WINDOW_SECONDS=60
APP_HMAC_SECRET=CHANGE_ME_SUPER_SECRET
MAX_CLOCK_SKEW_SEC=300
ANTI_REPLAY_TTL_SEC=600
MAX_REQUEST_BODY_BYTES=5000000
MODEL_BACKEND=onnx
MODEL_PATH=./models/bird_species.onnx
CLASS_NAMES_PATH=./models/class_names.json
INFERENCE_IMAGE_SIZE=224
INFERENCE_TOP_K=3
INFERENCE_REQUIRE_SIGNATURE=true
PRELOAD_MODEL_ON_STARTUP=false
FAIL_FAST_ON_STARTUP=false
ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp
IMAGE_MEAN=0.485,0.456,0.406
IMAGE_STD=0.229,0.224,0.225